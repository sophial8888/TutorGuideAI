# Chatbot frontend (frontend/) — Vite env vars, must be prefixed VITE_.

# Supabase project URL and anon (public) key — same values as the backend's
# SUPABASE_URL, plus the anon key from Project Settings -> API.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Deployed Flask backend's origin (no trailing slash), e.g. https://api.tutorguide.ai
# Leave unset for local dev — falls back to a relative path, handled by the
# Vite proxy in vite.config.js.
VITE_API_URL=

# Deployed landing page's URL, used for the "back to landing page" link.
# Falls back to http://localhost:5174 for local dev.
VITE_LANDING_URL=
