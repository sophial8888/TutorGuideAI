# Flask backend (app.py) — required at runtime.

# Groq API key used to call the LLM. https://console.groq.com/keys
GROQ_API_KEY=

# Your Supabase project URL, e.g. https://xxxxx.supabase.co
SUPABASE_URL=

# Supabase Dashboard -> Project Settings -> API -> JWT Settings -> "Legacy JWT secret".
# Used to verify HS256 tokens; ES256 tokens are verified via the project's JWKS
# endpoint instead (see verify_token() in app.py), so this is still required as
# a fallback even on projects using the newer asymmetric signing keys.
SUPABASE_JWT_SECRET=

# The deployed chatbot frontend's origin (no trailing slash), added to the
# CORS allowlist alongside the localhost dev origins. e.g. https://app.tutorguide.ai
PRODUCTION_URL=
