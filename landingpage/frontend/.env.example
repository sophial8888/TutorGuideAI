# Landing page frontend (landingpage/frontend/) — Vite env vars, must be prefixed VITE_.

# Supabase project URL and anon (public) key — same values as the backend's
# SUPABASE_URL, plus the anon key from Project Settings -> API.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Deployed chatbot frontend's URL (trailing slash), e.g. https://app.tutorguide.ai/
# New signups are redirected here after account creation. Falls back to
# http://localhost:5173/ for local dev.
VITE_CHATBOT_URL=
